# -----------------------------------------------------------------
# Root GitIgnore for Cravora (Frontend & Backend)
# -----------------------------------------------------------------

# Dependency directories
node_modules/
jspm_packages/
web_modules/

# Build and Output directories
dist/
dist-ssr/
build/
out/
target/
bin/
obj/
!**/src/main/**/target/
!**/src/test/**/target/
!**/src/main/**/build/
!**/src/test/**/build/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS metadata
.DS_Store
Thumbs.db
desktop.ini

# IDEs and Editors
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.class
*.iml
*.ipr
*.iws

# Eclipse / STS / NetBeans specific files
.metadata/
.classpath
.project
.settings/
.factorypath
.springBeans
.sts4-cache/
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/

# Maven / Gradle wrappers
.mvn/wrapper/maven-wrapper.jar

# Environment/Local variables config
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.local
